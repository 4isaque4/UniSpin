# API runtime
NODE_ENV=production
PORT=8080

# Security — JWT do login proprio (apps/api/src/routes/auth.routes.js)
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-esta-chave-por-uma-gerada-com-openssl
JWT_EXPIRES=2d

# Database (Postgres local no VPS)
DATABASE_URL=postgresql://unispin_app:senha-do-role@localhost:5432/unispin
FORCE_DB_SSL=false

# CORS (comma-separated, sem espaços)
FRONTEND_ORIGINS=https://unispin.sbs,https://www.unispin.sbs,http://localhost:5173
